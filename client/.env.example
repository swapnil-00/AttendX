# Client environment variables
# Copy this file to .env and fill in your values.
# ⚠️  NEVER commit the real .env file — it is in .gitignore.

# ── API URL ───────────────────────────────────────────────────────────────────
# Leave blank in development — Vite proxy handles /api → localhost:3001
# In production set this to your backend URL, e.g.:
# VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=

# ── API Key Auth (Fix #3) ─────────────────────────────────────────────────────
# Must match the API_KEY value in server/.env
VITE_API_KEY=your-strong-random-api-key-here
