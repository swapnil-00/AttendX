{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build && cd .. && mkdir -p dist && cp -r client/dist/* dist/",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/index.js"
    }
  ],
  "functions": {
    "server/index.js": {
      "runtime": "nodejs20.x"
    }
  }
}
